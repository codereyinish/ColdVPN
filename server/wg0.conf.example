# =============================================================================
# server/wg0.conf.example — WireGuard Server Config Template
# =============================================================================
# Copy this to /etc/wireguard/wg0.conf on your VPS and fill in the values.
#
# How to generate server keys:
#   wg genkey | tee /etc/wireguard/server_private.key | wg pubkey > /etc/wireguard/server_public.key
#
# NET_INTERFACE: your server's main network interface
#   Find it with: ip route | grep default | awk '{print $5}'
#   Usually: eth0, ens3, enp0s3 (varies by cloud provider)
# =============================================================================

[Interface]
PrivateKey = YOUR_SERVER_PRIVATE_KEY_HERE
Address    = 10.8.0.1/24
ListenPort = 443

# NAT rules — routes VPN client traffic to the internet
# Replace eth0 with your actual network interface
PostUp   = iptables -I FORWARD 1 -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE

# Add one [Peer] block per client (Mac)
[Peer]
PublicKey  = YOUR_CLIENT_PUBLIC_KEY_HERE
AllowedIPs = 10.8.0.2/32
