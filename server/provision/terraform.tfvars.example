# Copy this to terraform.tfvars and fill in your values. (terraform.tfvars is
# git-ignored — it holds your OCIDs and SSH key, which shouldn't be committed.)

region           = "us-ashburn-1"                      # your OCI region
compartment_ocid = "ocid1.tenancy.oc1..xxxxxxxxxxxx"   # tenancy OCID is fine for a personal setup
ssh_public_key   = "ssh-ed25519 AAAA...your-key... you@mac"  # contents of ~/.ssh/id_ed25519.pub

# ---- optional overrides (sensible defaults already set) ----
# oci_profile        = "DEFAULT"             # profile in ~/.oci/config
# instance_shape     = "VM.Standard.A1.Flex" # or "VM.Standard.E2.1.Micro"
# instance_ocpus     = 1                     # Flex only; A1 Always-Free allows up to 4
# instance_memory_gb = 6                     # Flex only; A1 Always-Free allows up to 24
# wg_port            = 443
# run_setup_on_boot  = true                  # cloud-init runs setup.sh on first boot
